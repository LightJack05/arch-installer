# config/defaults.env — opinionated defaults, sourced by cfg_init in lib/config.sh.
#
# Every value here is overridable from the TUI (stage 10) — the TUI pre-fills
# each prompt with the default so hitting Enter accepts it.
#
# Format: plain KEY=VALUE shell syntax (safe for `source`). No command substitution.

# --- Locale / time / keymap ------------------------------------------------
TIMEZONE='Europe/Berlin'
LOCALE='en_US.UTF-8'
KEYMAP='us'

# --- Identity --------------------------------------------------------------
HOSTNAME='archlinux'
USERNAME='lightjack05'
USER_FULLNAME=''
USER_SHELL='/usr/bin/zsh'

# --- Disk / FS -------------------------------------------------------------
INSTALL_MODE='A'           # A | B | C | D
FILESYSTEM='ext4'          # ext4 | btrfs
TARGET_DISK=''             # filled by TUI
MANUAL_MOUNT='/mnt'        # scheme D only

# --- Swap ------------------------------------------------------------------
# Sizes in MiB. Populated by the TUI from detected RAM.
SWAPFILE_SIZE_MIB=''       # default computed: RAM_MiB / 8, capped at 4 GiB
ZRAM_SIZE_MIB=''           # default computed: min(RAM_MiB / 2, 8192)

# --- Optional components ---------------------------------------------------
DOTFILES_ENABLED='1'       # 1 = opt in (default), 0 = skip
DOTFILES_REPO='https://github.com/LightJack05/dotfiles'
DOTFILES_SETUP_SCRIPT='setup-complete.sh'  # relative to the clone directory
SECURE_BOOT='0'            # 1 to enroll sbctl keys + sign UKI
KERNEL_LOCKDOWN='1'        # 1 = iommu=force + lockdown=confidentiality (default), 0 = skip
SURFACE_KERNEL='0'         # 1 to install linux-surface
